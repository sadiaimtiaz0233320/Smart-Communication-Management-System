    // ================= UPDATED SYSTEM MODULE =================
    JPanel system() {
        JPanel p = new JPanel(null);

        // Status buttons
        JButton toggleStatus = new JButton("Toggle Online/Offline");
        JButton viewStatus = new JButton("View All Status");
        JButton viewAllMessages = new JButton("View All Messages");
        JButton editMessage = new JButton("Edit Message");
        JButton deleteMessage = new JButton("Delete Message");
        JButton autoMsg = new JButton("Auto Message (5 sec)");
        JButton back = new JButton("Back");

        styleButton(toggleStatus);
        styleButton(viewStatus);
        styleButton(viewAllMessages);
        styleButton(editMessage);
        styleButton(deleteMessage);
        styleButton(autoMsg);
        styleButton(back);

        toggleStatus.setBounds(100,100,200,40);
        viewStatus.setBounds(320,100,200,40);
        viewAllMessages.setBounds(540,100,200,40);
        editMessage.setBounds(100,160,200,40);
        deleteMessage.setBounds(320,160,200,40);
        autoMsg.setBounds(540,160,200,40);
        back.setBounds(20,500,100,35);

        // ================= TOGGLE STATUS =================
        toggleStatus.addActionListener(e -> {
            String contact = JOptionPane.showInputDialog("Enter Contact Name:");
            if(contacts.contains(contact)) {
                boolean currentStatus = onlineStatus.getOrDefault(contact, false);
                onlineStatus.put(contact, !currentStatus);
                String status = !currentStatus ? "🟢 ONLINE" : "🔴 OFFLINE";
                JOptionPane.showMessageDialog(this, contact + " is now " + status);
            } else {
                JOptionPane.showMessageDialog(this, "Contact not found!");
            }
        });

        // ================= VIEW STATUS =================
        viewStatus.addActionListener(e -> {
            String allStatus = "📊 ONLINE/OFFLINE STATUS 📊\n\n";
            for(String contact : contacts) {
                boolean status = onlineStatus.getOrDefault(contact, false);
                String emoji = status ? "🟢 ONLINE" : "🔴 OFFLINE";
                allStatus += contact + " : " + emoji + "\n";
            }
            JOptionPane.showMessageDialog(this, allStatus, "Status Report", JOptionPane.INFORMATION_MESSAGE);
        });

        // ================= VIEW ALL MESSAGES WITH TABLE =================
        viewAllMessages.addActionListener(e -> {
            JFrame tableFrame = new JFrame("All Messages");
            tableFrame.setSize(800, 500);
            tableFrame.setLocationRelativeTo(null);

            String[] columns = {"Contact", "Message", "Status"};
            DefaultTableModel model = new DefaultTableModel(columns, 0);

            for(String contact : chats.keySet()) {
                boolean status = onlineStatus.getOrDefault(contact, false);
                String statusText = status ? "🟢 ONLINE" : "🔴 OFFLINE";
                
                for(String msg : chats.get(contact)) {
                    model.addRow(new Object[]{contact, msg, statusText});
                }
            }

            JTable table = new JTable(model);
            table.setRowHeight(25);
            JScrollPane scroll = new JScrollPane(table);
            
            JButton refresh = new JButton("Refresh");
            styleButton(refresh);
            refresh.addActionListener(ev -> {
                model.setRowCount(0);
                for(String contact : chats.keySet()) {
                    boolean status = onlineStatus.getOrDefault(contact, false);
                    String statusText = status ? "🟢 ONLINE" : "🔴 OFFLINE";
                    for(String msg : chats.get(contact)) {
                        model.addRow(new Object[]{contact, msg, statusText});
                    }
                }
            });

            tableFrame.setLayout(new BorderLayout());
            tableFrame.add(scroll, BorderLayout.CENTER);
            tableFrame.add(refresh, BorderLayout.SOUTH);
            tableFrame.setVisible(true);
        });

        // ================= EDIT MESSAGE =================
        editMessage.addActionListener(e -> {
            String contact = JOptionPane.showInputDialog("Enter Contact:");
            if(!chats.containsKey(contact)) {
                JOptionPane.showMessageDialog(this, "Contact not found!");
                return;
            }

            String oldMsg = JOptionPane.showInputDialog("Enter old message to edit:");
            ArrayList<String> messages = chats.get(contact);
            
            boolean found = false;
            for(int i = 0; i < messages.size(); i++) {
                if(messages.get(i).contains(oldMsg)) {
                    String newMsg = JOptionPane.showInputDialog("Enter new message:");
                    if(newMsg != null) {
                        messages.set(i, newMsg);
                        JOptionPane.showMessageDialog(this, "Message edited successfully!");
                        found = true;
                        break;
                    }
                }
            }
            if(!found) {
                JOptionPane.showMessageDialog(this, "Message not found!");
            }
        });

        // ================= DELETE MESSAGE =================
        deleteMessage.addActionListener(e -> {
            String contact = JOptionPane.showInputDialog("Enter Contact:");
            if(!chats.containsKey(contact)) {
                JOptionPane.showMessageDialog(this, "Contact not found!");
                return;
            }

            String msgToDelete = JOptionPane.showInputDialog("Enter message to delete:");
            ArrayList<String> messages = chats.get(contact);
            
            Iterator<String> iterator = messages.iterator();
            boolean deleted = false;
            
            while(iterator.hasNext()) {
                String msg = iterator.next();
                if(msg.contains(msgToDelete)) {
                    iterator.remove();
                    deleted = true;
                    JOptionPane.showMessageDialog(this, "Message deleted successfully!");
                    break;
                }
            }
            
            if(!deleted) {
                JOptionPane.showMessageDialog(this, "Message not found!");
            }
        });

        // ================= AUTO MESSAGE =================
        autoMsg.addActionListener(e -> {
            String msg = JOptionPane.showInputDialog("Enter Message");
            if(!contacts.isEmpty()) {
                String contact = contacts.getFirst();
                new javax.swing.Timer(5000, ev -> {
                    chats.get(contact).add("⏰ Auto: " + msg);
                    JOptionPane.showMessageDialog(this, "Auto sent to " + contact);
                }).start();
            }
        });

        back.addActionListener(e -> card.show(mainPanel,"login"));

        p.add(toggleStatus);
        p.add(viewStatus);
        p.add(viewAllMessages);
        p.add(editMessage);
        p.add(deleteMessage);
        p.add(autoMsg);
        p.add(back);

        // Title
        JLabel title = new JLabel("🛠️ SYSTEM AUTOMATION PANEL 🛠️", JLabel.CENTER);
        title.setBounds(0, 20, 950, 40);
        title.setFont(new Font("Segoe UI", Font.BOLD, 20));
        title.setForeground(Color.BLUE);
        p.add(title);

        applyTheme(p);
        return p;
    }

    // ================= MOOD / THEME =================
    JPanel mood() {
        JPanel p = new JPanel(null);
        String[] moods = {"❤️ Love", "💕 Friendly", "🤎 Calm", "💙 Cool", "😎 Night", "🌇 Sunset", "👑 Royal", "🌿 Fresh"};
        Color[] colors = {Color.RED, Color.PINK, new Color(245,245,220), Color.CYAN, Color.DARK_GRAY, Color.ORANGE, new Color(128,0,128), Color.GREEN};

        int x = 80, y = 150;
        for(int i=0; i<moods.length; i++) {
            JButton b = new JButton(moods[i]);
            styleButton(b);
            b.setBounds(x,y,150,40);
            Color c = colors[i];
            final int index = i;
            b.addActionListener(e -> {
                theme = c;
                applyTheme(mainPanel);
                repaint();
            });
            p.add(b);
            x += 170;
            if(x > 700) {
                x = 80;
                y += 70;
            }
        }

        JButton back = new JButton("Back");
        styleButton(back);
        back.setBounds(20,500,100,35);
        back.addActionListener(e -> card.show(mainPanel,"login"));
        p.add(back);
        applyTheme(p);
        return p;
    }

