    // ================= CONSTRUCTOR =================
    public WhatsAppSystem() {
        setTitle("Chat With Our WhatsApp");
        setSize(950,600);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(EXIT_ON_CLOSE);

        // Screens
        mainPanel.add(login(),"login");
        mainPanel.add(user(),"user");
        mainPanel.add(admin(),"admin");
        mainPanel.add(system(),"system");
        mainPanel.add(mood(),"mood");
        mainPanel.add(thankyou(),"thank");

        add(mainPanel);
        card.show(mainPanel,"login");

        // ================= AUTO DELETE =================
        new javax.swing.Timer(8000, e -> {
            for(String u : chats.keySet()) {
                if(!chats.get(u).isEmpty()) {
                    chats.get(u).remove(0);
                }
            }
        }).start();

        setVisible(true);
    }

    // ================= APPLY THEME =================
    void applyTheme(Container c) {
        c.setBackground(theme);
        for(Component comp : c.getComponents()) {
            if(comp instanceof JPanel)
                applyTheme((Container) comp);
        }
    }

