    // ================= USER MODULE =================
    JPanel user() {
        JPanel p = new JPanel(null);
        JButton add = new JButton("Add Contact");
        JButton send = new JButton("Send Message");
        JButton view = new JButton("View Chat");
        JButton starBtn = new JButton("Starred Messages");
        JButton pic = new JButton("Send Picture");
        JButton note = new JButton("Open Notepad");
        JButton back = new JButton("Back");

        styleButton(add);
        styleButton(send);
        styleButton(view);
        styleButton(starBtn);
        styleButton(pic);
        styleButton(note);
        styleButton(back);

        add.setBounds(100,120,200,40);
        send.setBounds(350,120,200,40);
        view.setBounds(600,120,200,40);
        starBtn.setBounds(100,220,200,40);
        pic.setBounds(350,220,200,40);
        note.setBounds(600,220,200,40);
        back.setBounds(20,500,100,35);

        // ================= ADD CONTACT =================
        add.addActionListener(e -> {
            String name = JOptionPane.showInputDialog("Enter Contact");
            if(name != null) {
                contacts.add(name);
                chats.put(name,new ArrayList<>());
                onlineStatus.put(name, false); // Initially offline
                JOptionPane.showMessageDialog(this, "Contact Added Successfully");
            }
        });

        // ================= SEND MESSAGE (same as before) =================
        send.addActionListener(e -> {
            JFrame f = new JFrame("Send Message");
            f.setSize(400,300);
            f.setLayout(null);

            JComboBox<String> box = new JComboBox<>(contacts.toArray(new String[0]));
            box.setBounds(50,40,300,30);
            JTextField msg = new JTextField();
            msg.setBounds(50,90,300,30);
            JButton s = new JButton("Send");
            styleButton(s);
            s.setBounds(130,150,120,30);

            s.addActionListener(ev -> {
                String c = (String) box.getSelectedItem();
                if(c == null) return;

                String[] moods = {"❤️", "😡", "😊", "😎"};
                String mood = (String) JOptionPane.showInputDialog(null, "Select Mood", "Mood", JOptionPane.QUESTION_MESSAGE, null, moods, moods[0]);
                String finalMsg = mood + " " + msg.getText();

                chats.get(c).add(finalMsg);

                // ================= STAR MESSAGE =================
                int star = JOptionPane.showConfirmDialog(null, "Star this message?");
                if(star == 0) starred.add(finalMsg);

                // ================= SMART REPLY =================
                String[] replies = {"OK", "Thanks", "Busy", "Call me"};
                String reply = (String) JOptionPane.showInputDialog(null, "Smart Reply", "Reply", JOptionPane.QUESTION_MESSAGE, null, replies, replies[0]);
                if(reply != null) chats.get(c).add("Auto: " + reply);

                JOptionPane.showMessageDialog(f, "Message Sent to " + c);
            });

            f.add(box);
            f.add(msg);
            f.add(s);
            f.add(new JLabel("To:", JLabel.RIGHT), new Rectangle(20,45,25,20));
            f.add(new JLabel("Message:", JLabel.RIGHT), new Rectangle(20,95,35,20));
            f.setVisible(true);
        });

        // Other buttons remain same...
        view.addActionListener(e -> {
            String name = JOptionPane.showInputDialog("Enter Contact");
            if(chats.containsKey(name)) {
                String all = "";
                for(String m : chats.get(name)) all += m + "\n";
                JOptionPane.showMessageDialog(this, all);
            }
        });

        starBtn.addActionListener(e -> {
            String all = "";
            for(String s : starred) all += s + "\n";
            JOptionPane.showMessageDialog(this, all);
        });

        pic.addActionListener(e -> {
            JFileChooser chooser = new JFileChooser();
            FileNameExtensionFilter filter = new FileNameExtensionFilter("Images", "jpg", "png", "jpeg");
            chooser.setFileFilter(filter);
            int result = chooser.showOpenDialog(null);
            if(result == JFileChooser.APPROVE_OPTION) {
                File selected = chooser.getSelectedFile();
                String contact = JOptionPane.showInputDialog("Send to which contact?");
                if(chats.containsKey(contact)) {
                    chats.get(contact).add("📷 Picture Sent: " + selected.getAbsolutePath());
                    JOptionPane.showMessageDialog(this, "Picture Sent Successfully");
                }
            }
        });

        note.addActionListener(e -> {
            JFrame noteFrame = new JFrame("My Notepad");
            noteFrame.setSize(500,400);
            noteFrame.setLocationRelativeTo(null);
            JTextArea area = new JTextArea();
            JScrollPane scroll = new JScrollPane(area);
            JButton save = new JButton("Save Notes");
            styleButton(save);

            save.addActionListener(ev -> {
                try {
                    FileWriter writer = new FileWriter("notes.txt");
                    writer.write(area.getText());
                    writer.close();
                    JOptionPane.showMessageDialog(noteFrame, "Notes Saved Successfully");
                } catch(Exception ex) {
                    JOptionPane.showMessageDialog(noteFrame, "Error Saving File");
                }
            });

            noteFrame.setLayout(new BorderLayout());
            noteFrame.add(scroll, BorderLayout.CENTER);
            noteFrame.add(save, BorderLayout.SOUTH);
            noteFrame.setVisible(true);
        });

        back.addActionListener(e -> card.show(mainPanel,"login"));

        p.add(add);
        p.add(send);
        p.add(view);
        p.add(starBtn);
        p.add(pic);
        p.add(note);
        p.add(back);

        applyTheme(p);
        return p;
    }

